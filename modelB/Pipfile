# PY3-MIGRATED: reconciled with requirements.txt (the build-authoritative manifest)
# and retargeted to Python 3.10. The original Pipfile disagreed with
# requirements.txt (mysqlclient 1.4.2 vs MySQL-python 1.2.5; pandas 0.23.4 vs
# 0.19.2; requests 2.20.0 vs 2.18.4; boto v2 in both; six only in requirements).
# Versions below now match requirements.txt exactly. See report Assumptions.

[[source]]
name = "pypi"
url = "https://pypi.org/simple"
verify_ssl = true

[packages]
# PY3-MIGRATED: boto (EOL, Python 2) -> boto3. NOT a drop-in replacement. FLAGGED (HIGH).
boto3 = "==1.34.131"
# PY3-MIGRATED: mysqlclient bumped 1.4.2 -> 2.2.4 for Python 3.10. Keeps `import MySQLdb`. FLAGGED.
mysqlclient = "==2.2.4"
# PY3-MIGRATED: pandas 0.23.4 -> 1.5.3 (Python 3.10). FLAGGED (HIGH) - see requirements.txt note.
pandas = "==1.5.3"
# PY3-MIGRATED: requests 2.20.0 -> 2.32.3. RESOLVED.
requests = "==2.32.3"
# PY3-MIGRATED: added six to match requirements.txt (was absent here). Advisory.
six = "==1.16.0"

[requires]
python_version = "3.10"  # PY3-MIGRATED: was "2.7"
